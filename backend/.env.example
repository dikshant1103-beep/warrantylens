# Backend environment. Copy to .env and adjust.
APP_NAME=WarrantyLens
ENVIRONMENT=development
DEBUG=true

# Database (async driver)
DATABASE_URL=postgresql+asyncpg://warrantylens:warrantylens@localhost:5432/warrantylens

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — CHANGE IN PRODUCTION (generate: python -c "import secrets;print(secrets.token_urlsafe(64))")
JWT_SECRET=dev-insecure-change-me-please-0123456789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Seed admin (used by app.scripts.seed)
SEED_TENANT_NAME=Demo EV Service
SEED_TENANT_SLUG=demo
SEED_ADMIN_EMAIL=admin@demo.warrantylens.io
SEED_ADMIN_PASSWORD=Admin12345!

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=warrantylens
S3_REGION=us-east-1

# --- AI pipeline (Sprint 3) ---
# Master switch. Leave false to run the full app without any heavy models
# (AI stages are cleanly SKIPPED). Turn on per-model below once installed.
AI_ENABLED=false

# VLM: Qwen2.5-VL via Ollama (benchmarked locally). Run `ollama serve` + pull qwen2.5vl:7b.
VLM_ENABLED=false
OLLAMA_URL=http://localhost:11434
VLM_MODEL=qwen2.5vl:7b
VLM_MAX_KEYFRAMES=10

# Whisper ASR (needs pip install -e ".[ai]")
ASR_ENABLED=false
WHISPER_MODEL=base

# YOLOv11 detection (needs ".[ai]"; swap weights for a fine-tuned EV checkpoint)
YOLO_ENABLED=false
YOLO_WEIGHTS=yolo11n.pt

# PaddleOCR (needs ".[ai]")
OCR_ENABLED=false

# BGE-M3 embeddings + Qdrant (needs ".[ai]")
EMBEDDINGS_ENABLED=false
QDRANT_URL=http://localhost:6333

# --- Hardening (Sprint 5) ---
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10
MAX_UPLOAD_MB=500
# In ENVIRONMENT=production the app refuses to start with a default JWT_SECRET,
# DEBUG=true, or default MinIO creds. Generate a real secret:
#   python -c "import secrets;print(secrets.token_urlsafe(64))"
